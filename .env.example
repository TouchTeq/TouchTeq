# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=AIzaSyDe94jQ3JgyLS7lgwYwmqYMCWcL9_3pK7Q

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase: Required for Auth and Database
NEXT_PUBLIC_SUPABASE_URL=https://iwmaksswkffypmnfvzqa.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-role-key-here]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key-here]

# Cloudflare Turnstile: Required for form bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY="your-site-key"
TURNSTILE_SECRET_KEY="your-secret-key"

# Brevo (formerly Sendinblue): Required for sending emails
BREVO_API_KEY="your-brevo-api-key"
BREVO_LIST_ID="your-brevo-list-id"

# Email Addresses: Used for outbound email sender addresses
SALES_EMAIL="sales@touchteq.co.za"
ACCOUNTS_EMAIL="accounts@touchteq.co.za"

# API Key Encryption: Required for BYOK (Bring Your Own Key) feature
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be a 64-character hex string (32 bytes). Never expose to the browser.
ENCRYPTION_KEY="your-64-char-hex-encryption-key"