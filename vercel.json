{
  "crons": [
    {
      "path": "/api/cron/run-sequences",
      "schedule": "0 4 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "touchteq.co.za"
        }
      ],
      "destination": "https://www.touchteq.co.za/:path*",
      "permanent": true
    }
  ]
}
